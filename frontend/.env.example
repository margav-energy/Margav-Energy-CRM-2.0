# Public API base URL (must include /api). Set in Render (Static Site) for production builds.
VITE_API_URL=http://localhost:3001/api

# Google Calendar — read-only iframe (Calendar → Integrate calendar → copy iframe src).
# VITE_GOOGLE_CALENDAR_EMBED_URL=https://calendar.google.com/calendar/embed?src=c_3c9fc2595de3b29e89bae6a30017d9d0d413b72932f1d5c37811cf9861c18253%40group.calendar.google.com&ctz=Europe%2FLondon
# Full web app for creating/editing events (optional — auto-built from calendar id if unset):
# VITE_GOOGLE_CALENDAR_WEB_URL=https://calendar.google.com/calendar/u/0/r/week?cid=...
# VITE_GOOGLE_CALENDAR_ID=c_3c9fc2595de3b29e89bae6a30017d9d0d413b72932f1d5c37811cf9861c18253@group.calendar.google.com
