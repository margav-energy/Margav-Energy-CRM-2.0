// Margav Energy CRM - Prisma Schema
// Solar/Energy sales CRM with role-based workflows

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
  QUALIFIER
  FIELD_SALES
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  DEPOSITION
  QUALIFYING
  QUALIFIED
  SOLD
  NOT_QUALIFIED
  APPOINTMENT_SET
  NO_CONTACT      // Qualifier: couldn't reach lead
  QUALIFIER_CALLBACK  // Qualifier: need to call back
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OpportunityStage {
  PITCH_SCHEDULED
  PITCH_COMPLETED
  WON
  LOST
}

enum ProductType {
  SOLAR
  BATTERY
  EV_CHARGER
  BUNDLE
}

// Business line for a lead (agent → qualifier), separate from opportunity product mix
enum LeadProductLine {
  SOLAR
  HEATING
}

enum TaskType {
  CALL
  EMAIL
  MEETING
  FOLLOW_UP
  PROPOSAL
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum NoteEntityType {
  LEAD
  APPOINTMENT
  OPPORTUNITY
}

enum SmsThreadStatus {
  ACTIVE
  ARCHIVED
}

enum SmsDirection {
  INBOUND
  OUTBOUND
}

enum SmsDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

// SMS Lead Journey - automation stage (separate from LeadStatus)
enum SmsAutomationStage {
  INITIAL_SMS_PENDING   // Lead created, waiting to send
  INITIAL_SMS_SENT      // First SMS sent
  AWAITING_QUALIFIER   // Office hours: qualifier callback due
  AWAITING_REPLY       // Outside hours: waiting for customer reply
  REPLY_RECEIVED       // Customer replied, callback scheduled
  CHASE_CALL_DUE       // No reply, chase call for next office hours
  APPOINTMENT_BOOKED   // Appointment created
  SURVEYOR_ON_ROUTE    // Surveyor on route SMS sent (optional)
  COMPLETED            // Final outcome logged
}

// Qualifier call outcomes (office hours flow)
enum CallOutcome {
  WRONG_NUMBER
  NOT_INTERESTED
  APPOINTMENT_BOOKED
  NO_ANSWER
  CALLBACK_REQUESTED
}

// Final appointment outcomes (post-survey)
enum AppointmentOutcome {
  PITCH_AND_MISS
  SALE_WON
  SWEEP
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  // Login id (stored lowercase, e.g. johnd)
  username  String   @unique
  // Optional; legacy / notifications
  email     String?  @unique
  passwordHash String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - leads assigned as agent
  leadsAsAgent           Lead[]         @relation("AssignedAgent")
  // Relations - leads assigned as qualifier
  leadsAsQualifier       Lead[]         @relation("AssignedQualifier")
  // Leads this user qualified (agent pool or post–qualify attribution)
  leadsQualifiedBy       Lead[]         @relation("QualifiedByQualifier")
  // Relations - leads assigned as field sales
  leadsAsFieldSales      Lead[]         @relation("AssignedFieldSales")
  // Appointments as field sales rep
  appointments          Appointment[]
  // Opportunities owned
  opportunities         Opportunity[]
  // Tasks assigned
  tasksAssigned         Task[]         @relation("TaskAssignee")
  // Tasks created
  tasksCreated          Task[]         @relation("TaskCreator")
  // Status history
  leadStatusChanges     LeadStatusHistory[]
  // Notes created
  notes                 Note[]
  // Call logs (qualifier outcomes)
  callLogs              CallLog[]
}

model Lead {
  id                    String      @id @default(cuid())
  firstName             String
  lastName              String
  phone                 String
  email                 String
  addressLine1          String?
  addressLine2          String?
  city                  String?
  postcode              String?
  state                 String?
  country               String?
  source                String?
  status                LeadStatus  @default(NEW)
  companyName           String?
  industry              String?
  leadScore             Int?
  nextAction            String?
  nextActionDate        DateTime?
  campaign              String?
  originalLeadId        String?     // ID from source system (BLC, Rattle, Leadwise)
  smsAutomationPaused   Boolean     @default(false) // Admin: stop automated outbound SMS / journey timers
  priority              Boolean     @default(false) // Admin: highlight in queues
  duplicateOfLeadId     String?     // This lead is a suspected duplicate of another (canonical) lead
  duplicateOfLead       Lead?       @relation("LeadDuplicateOf", fields: [duplicateOfLeadId], references: [id], onDelete: SetNull)
  markedAsDuplicates    Lead[]      @relation("LeadDuplicateOf")
  smsAutomationStage    SmsAutomationStage?
  interestLevel         String?     // high, medium, low
  homeowner             Boolean?
  monthlyEnergyBill     Decimal?    @db.Decimal(10, 2)
  notes                 String?    @db.Text
  depositionReason      String?
  roofCondition         String?    // excellent, good, fair, poor
  productLine           LeadProductLine?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // Qualifier lead sheet fields
  qualifierNotes        String?    @db.Text
  qualifierCallbackDate DateTime?
  desktopRoofCheckCompleted Boolean?
  propertyTypeQualifier String?
  roofTypeQualifier     String?
  speakingToHomeowner   Boolean?
  bothHomeownersPresent Boolean?
  propertyListed        Boolean?
  conservationArea      Boolean?
  buildingWorkOngoing   Boolean?
  roofShadedObstructed  Boolean?
  sprayFoamRoof         Boolean?
  customerAwareNoGrants Boolean?
  currentElectricBillType String?
  customerAge           Int?
  aged18To70            Boolean?
  currentlyEmployed     Boolean?
  hasGoodCredit         Boolean?
  earnsOver12k          Boolean?
  planningToMove5Years  Boolean?
  available3WorkingDays Boolean?

  assignedAgentId       String?
  assignedAgent         User?       @relation("AssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  assignedQualifierId   String?
  assignedQualifier     User?       @relation("AssignedQualifier", fields: [assignedQualifierId], references: [id], onDelete: SetNull)
  qualifiedByQualifierId String?
  qualifiedByQualifier  User?       @relation("QualifiedByQualifier", fields: [qualifiedByQualifierId], references: [id], onDelete: SetNull)
  assignedFieldSalesRepId String?
  assignedFieldSalesRep User?       @relation("AssignedFieldSales", fields: [assignedFieldSalesRepId], references: [id], onDelete: SetNull)

  statusHistory         LeadStatusHistory[]
  appointments          Appointment[]
  opportunities         Opportunity[]
  tasks                 Task[]
  noteRecords           Note[]
  smsThreads            SmsThread[]
  callLogs              CallLog[]
  activityEvents       ActivityEvent[]

  @@index([status])
  @@index([smsAutomationStage])
  @@index([source])
  @@index([assignedAgentId])
  @@index([assignedQualifierId])
  @@index([qualifiedByQualifierId])
  @@index([assignedFieldSalesRepId])
  @@index([createdAt])
  @@index([duplicateOfLeadId])
  @@index([smsAutomationPaused])
  @@index([productLine])
}

model LeadStatusHistory {
  id              String    @id @default(cuid())
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus      LeadStatus?
  toStatus        LeadStatus
  changedByUserId String
  changedByUser   User      @relation(fields: [changedByUserId], references: [id], onDelete: Cascade)
  note            String?   @db.Text
  createdAt       DateTime  @default(now())

  @@index([leadId])
}

model Appointment {
  id                  String              @id @default(cuid())
  leadId              String
  lead                Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fieldSalesRepId     String
  fieldSalesRep       User                @relation(fields: [fieldSalesRepId], references: [id], onDelete: Cascade)
  scheduledAt         DateTime
  status              AppointmentStatus   @default(SCHEDULED)
  notes               String?             @db.Text
  outcome             AppointmentOutcome? // PITCH_AND_MISS, SALE_WON, SWEEP
  surveyorOnRouteSentAt DateTime?        // When "surveyor on route" SMS was sent
  googleCalendarEventId String?          // Google Calendar API event id when synced
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  notesRelation   Note[]

  @@index([leadId])
  @@index([fieldSalesRepId])
  @@index([scheduledAt])
  @@index([status])
}

model Opportunity {
  id              String           @id @default(cuid())
  leadId          String
  lead            Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  stage          OpportunityStage @default(PITCH_SCHEDULED)
  productType    ProductType
  estimatedValue Decimal          @db.Decimal(12, 2)
  notes          String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tasks           Task[]
  notesRelation   Note[]

  @@index([leadId])
  @@index([ownerId])
  @@index([stage])
}

model Task {
  id                String       @id @default(cuid())
  title             String
  description       String?      @db.Text
  type              TaskType
  status            TaskStatus   @default(PENDING)
  priority          TaskPriority @default(MEDIUM)
  dueDate           DateTime
  assignedToUserId  String
  assignedToUser    User         @relation("TaskAssignee", fields: [assignedToUserId], references: [id], onDelete: Cascade)
  createdByUserId   String
  createdByUser     User         @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  leadId            String?
  lead              Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  opportunityId     String?
  opportunity       Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([assignedToUserId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([status])
  @@index([dueDate])
}

model Note {
  id            String         @id @default(cuid())
  content       String         @db.Text
  entityType      NoteEntityType
  createdByUserId String
  createdByUser User           @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())

  leadId        String?
  lead          Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity?    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([entityType])
  @@index([leadId])
  @@index([appointmentId])
  @@index([opportunityId])
}

// SMS - prepared for future Twilio integration
model SmsThread {
  id                    String          @id @default(cuid())
  leadId                String
  lead                  Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  phone                 String
  status                SmsThreadStatus @default(ACTIVE)
  lastMessageAt         DateTime?
  bookedViaSms          Boolean         @default(false)
  customerReplyAt       DateTime?       // When customer first replied (outside hours flow)
  qualifyingQuestionsReply String?      @db.Text  // Customer's reply to qualifying questions
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  messages      SmsMessage[]

  @@unique([leadId, phone])
  @@index([leadId])
}

model SmsMessage {
  id               String            @id @default(cuid())
  threadId         String
  thread           SmsThread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  direction        SmsDirection
  providerMessageId String?
  body             String           @db.Text
  deliveryStatus   SmsDeliveryStatus @default(PENDING)
  automationEventId String?         // Idempotency: link to ActivityEvent that triggered send
  createdAt        DateTime         @default(now())

  @@index([threadId])
}

// Call log - qualifier callback outcomes
model CallLog {
  id              String    @id @default(cuid())
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  outcome         CallOutcome
  notes           String?   @db.Text
  createdByUserId String?
  createdByUser   User?     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())

  @@index([leadId])
}

// Activity timeline - audit events for SMS journey
model ActivityEvent {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  eventType   String   // INITIAL_SMS_SENT, QUALIFIER_TASK_CREATED, INBOUND_REPLY, etc.
  metadata    Json?    // Extra context
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([eventType])
  @@index([createdAt])
}
