# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/margav_crm_2.0?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS - comma-separated origins (use * for development)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Twilio SMS - see docs/TWILIO_SMS_SETUP.md for setup
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_WEBHOOK_SECRET=  # Optional: for webhook signature validation

# Lead import (Google Sheets) - see docs/LEAD_IMPORT_INTEGRATION.md
# LEAD_IMPORT_API_KEY=  # Required for POST /api/leads/import

# Rattle & Leadwise — qualifier username(s), lowercase (comma-separated)
# SPECIAL_SHEETS_QUALIFIER_USERNAMES=louis
# Optional legacy: match by email
# SPECIAL_SHEETS_QUALIFIER_EMAILS=
#
# Google Sheets API — pick ONE auth method (see backend/scripts/google-sheets-oauth-setup.md):
# (A) API key — sheets shared "Anyone with the link" Viewer + restrict key to Sheets API
# GOOGLE_SHEETS_API_KEY=
# (B) OAuth — no service account key; use OAuth client + refresh token from OAuth Playground
# GOOGLE_SHEETS_OAUTH_CLIENT_ID=
# GOOGLE_SHEETS_OAUTH_CLIENT_SECRET=
# GOOGLE_SHEETS_OAUTH_REFRESH_TOKEN=
# (C) Service account JSON — if your org allows key creation
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=  # or GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON_B64

# Google Calendar API — appointment sync (see backend/scripts/google-calendar-oauth-setup.md)
# Reuses OAuth client above; refresh token must include Calendar scope (or use GOOGLE_CALENDAR_OAUTH_REFRESH_TOKEN).
# GOOGLE_CALENDAR_ENABLED=true
# GOOGLE_CALENDAR_ID=c_3c9fc2595de3b29e89bae6a30017d9d0d413b72932f1d5c37811cf9861c18253@group.calendar.google.com
# GOOGLE_CALENDAR_TIMEZONE=Europe/London
# GOOGLE_CALENDAR_DEFAULT_DURATION_MINUTES=60
# GOOGLE_CALENDAR_OAUTH_REFRESH_TOKEN=  # optional; else Sheets/OAuth refresh token is used

# SMS journey
# QUALIFIER_CALLBACK_MINUTES=15  # Office hours: "call within X minutes"
